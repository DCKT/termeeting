{
  "name": "termeeting",
  "version": "1.2.0",
  "description": "CLI for Google Calendar (read-only)",
  "type": "module",
  "bin": {
    "termeeting": "./dist/termeeting"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "build": "bun build --compile --target=bun-darwin-arm64 ./src/main.ts --outfile dist/termeeting",
    "release": "semantic-release",
    "prepare": "effect-language-service patch && effect-tsgo patch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@effect/cli": "^0.75.2",
    "@effect/platform": "^0.96.2",
    "@effect/platform-bun": "^0.90.0",
    "effect": "^3.21.4"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@effect/tsgo": "0.14.6",
    "@effect/vitest": "^0.29.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "@typescript/native-preview": "latest",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6",
    "semantic-release": "^24.2.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/github": "^11.0.2",
    "@semantic-release/git": "^10.0.1"
  }
}
